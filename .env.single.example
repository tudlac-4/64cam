# Copy to .env.single and fill in before running docker-compose.single.yml
# docker compose -f docker-compose.single.yml --env-file .env.single up -d

# ── Required ──────────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 48
JWT_SECRET=

# Your domain or LAN IP.
# Real domain   → Caddy provisions a Let's Encrypt certificate automatically.
# LAN IP / name → Caddy issues a self-signed cert (browser shows a warning).
DOMAIN=192.168.1.10

# ── Optional ──────────────────────────────────────────────────────────────────
# Database password (default is fine for single-machine private deployments)
DB_PASSWORD=cam64_dev

# Log level: error | warn | info | debug | trace
RUST_LOG=info

# ── S3 / MinIO tiered storage (optional) ─────────────────────────────────────
# Leave S3_ENDPOINT blank to store all recordings on local disk.
S3_ENDPOINT=
S3_BUCKET=64cam-recordings
S3_KEY_ID=
S3_SECRET_KEY=
S3_REGION=us-east-1
S3_PATH_STYLE=true
S3_MIGRATE_AFTER_HOURS=2
