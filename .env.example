# Main deployment env file — used by docker-compose.yml
# Copy to .env and fill in before running: cp .env.example .env

# ── Required ──────────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 48
JWT_SECRET=change-me-to-a-random-32-plus-byte-secret

# ── Recommended ───────────────────────────────────────────────────────────────
DB_PASSWORD=cam64_dev

# ── TLS profile (docker compose --profile tls up -d) ─────────────────────────
# Real domain → Let's Encrypt auto-HTTPS
# LAN IP      → self-signed cert
DOMAIN=localhost

# ── Port overrides (optional) ─────────────────────────────────────────────────
COORDINATOR_PORT=8080
RTSP_PORT=8554
WEBRTC_PORT=8889
NODE_HTTP_PORT=8890

# ── Logging ───────────────────────────────────────────────────────────────────
RUST_LOG=info

# ── S3 / MinIO tiered storage (optional) ─────────────────────────────────────
# Leave S3_ENDPOINT blank to keep recordings on local disk
S3_ENDPOINT=
S3_BUCKET=64cam-recordings
S3_KEY_ID=
S3_SECRET_KEY=
S3_REGION=us-east-1
S3_PATH_STYLE=true
S3_MIGRATE_AFTER_HOURS=2
