# Copy this file to .env.node and fill in the values before running
# docker compose -f docker-compose.node.yml up -d

# ── Required ──────────────────────────────────────────────────────────────────
# URL of the coordinator (must be reachable from this machine)
COORDINATOR_URL=http://coordinator:8080

# ── Node identity ─────────────────────────────────────────────────────────────
# Option A: Pre-provisioned by an admin (recommended for production)
#   1. Admin calls: POST /api/v1/nodes  { "name": "node-2" }
#   2. Copy the returned node_id and api_key here.
#   The node joins immediately as approved — no wait for admin approval.
NODE_ID=
NODE_API_KEY=

# Option B: Self-registration (leave NODE_ID and NODE_API_KEY blank)
#   The node registers itself on first boot with status=pending.
#   An admin must approve it at POST /api/v1/nodes/:id/status { "status": "approved" }
#   before cameras are synced.

# Human-readable label shown in the UI (defaults to the system hostname)
NODE_NAME=node-2

# ── Storage ───────────────────────────────────────────────────────────────────
# Directory for recordings, MediaMTX config and node state (default: /data)
DATA_DIR=/data

# ── S3 / MinIO tiered storage (optional) ─────────────────────────────────────
# Leave S3_ENDPOINT blank to keep all recordings on local disk.
# When set, segments older than S3_MIGRATE_AFTER_HOURS hours are uploaded to
# S3 and deleted from disk.  The coordinator serves them via presigned redirect.
S3_ENDPOINT=
S3_BUCKET=64cam-recordings
S3_KEY_ID=
S3_SECRET_KEY=
S3_REGION=us-east-1
# Set to "true" for MinIO and other path-style services; "false" for AWS virtual-hosted
S3_PATH_STYLE=true
S3_MIGRATE_AFTER_HOURS=2

# ── Network ports ─────────────────────────────────────────────────────────────
# Change these if a second node runs on the same host as the first
# (map different host ports to the same container ports)
# NODE_HTTP_PORT=8890
